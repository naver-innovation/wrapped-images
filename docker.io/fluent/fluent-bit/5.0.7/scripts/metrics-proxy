#!/usr/bin/env python3
"""fluent-bit prometheus metrics 경로 alias proxy.

fluent-bit HTTP_Server의 /api/v1/metrics/prometheus는 path가 고정되어 있어
컨테이너별 공통 metrics path 를 요구하는 multi-container scrape 환경에
직접 매핑할 수 없다. 본 프록시가 별도 포트에서 커스텀 path를 받아
upstream으로 중계한다.

필수 환경변수 (둘 다 설정된 경우에만 fluent-bit-entrypoint.sh가 실행):
  METRICS_PROXY_PATH      예) "/actuator/prometheus", "/metrics"
  METRICS_PROXY_PORT      예) "2021"

선택 환경변수:
  METRICS_PROXY_UPSTREAM  (기본 "http://127.0.0.1:2020/api/v1/metrics/prometheus")
  METRICS_PROXY_TIMEOUT   (기본 "3", 초)
"""
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.request import urlopen
from urllib.error import URLError, HTTPError
import os
import sys

try:
    PORT = int(os.environ["METRICS_PROXY_PORT"])
    EXPOSE_PATH = os.environ["METRICS_PROXY_PATH"]
except KeyError as e:
    sys.stderr.write(f"metrics-proxy: required env not set: {e}\n")
    sys.exit(2)

UPSTREAM = os.environ.get(
    "METRICS_PROXY_UPSTREAM",
    "http://127.0.0.1:2020/api/v1/metrics/prometheus",
)
TIMEOUT = float(os.environ.get("METRICS_PROXY_TIMEOUT", "3"))


class Handler(BaseHTTPRequestHandler):
    def _proxy(self, include_body):
        if self.path != EXPOSE_PATH:
            self.send_error(404, "Not Found")
            return
        try:
            with urlopen(UPSTREAM, timeout=TIMEOUT) as resp:
                body = resp.read()
                ctype = resp.headers.get("Content-Type", "text/plain; version=0.0.4")
                self.send_response(resp.status)
                self.send_header("Content-Type", ctype)
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                if include_body:
                    self.wfile.write(body)
        except HTTPError as e:
            self.send_error(e.code, "upstream error")
        except URLError as e:
            sys.stderr.write(f"metrics-proxy: upstream unreachable: {e.reason}\n")
            self.send_error(502, "upstream unreachable")
        except Exception as e:
            sys.stderr.write(f"metrics-proxy: unexpected error: {e}\n")
            self.send_error(500, "internal error")

    def do_GET(self):
        self._proxy(include_body=True)

    def do_HEAD(self):
        self._proxy(include_body=False)

    def log_message(self, *args, **kwargs):
        return


def main():
    srv = ThreadingHTTPServer(("0.0.0.0", PORT), Handler)
    sys.stderr.write(
        f"metrics-proxy: :{PORT}{EXPOSE_PATH} -> {UPSTREAM} (timeout={TIMEOUT}s)\n"
    )
    sys.stderr.flush()
    srv.serve_forever()


if __name__ == "__main__":
    main()
